#!/bin/bash
# Auto-runs after every `git pull`. Regenerates AccessFlow.xcodeproj.

# Locate xcodegen (Homebrew Apple Silicon / Intel / local bin)
for p in "/opt/homebrew/bin" "/usr/local/bin" "$HOME/.local/bin"; do
  [ -x "$p/xcodegen" ] && export PATH="$p:$PATH" && break
done

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROJECT_DIR="$REPO_ROOT/frontend/AccessFlow"

[ -f "$PROJECT_DIR/project.yml" ] || exit 0

if ! command -v xcodegen &>/dev/null; then
  echo "[post-merge] XcodeGen not found. Run: bash scripts/mac-setup.sh"
  exit 0
fi

echo "[post-merge] Regenerating AccessFlow.xcodeproj..."
(cd "$PROJECT_DIR" && xcodegen generate --quiet)
echo "[post-merge] Done — Xcode will prompt to reload."
